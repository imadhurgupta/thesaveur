# ── Python & OS ───────────────────────────────────────────
.venv/
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# ── Environment & Secrets (NEVER commit these) ─────────────
.env
.env.*
!.env.example

# ── Database (persistent data, not in Git) ─────────────────
*.db
*.sqlite
*.sqlite3

# ── Docker volumes & build artifacts ──────────────────────
*.tar
*.log

# ── IDE ────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── OS files ──────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── SSL certs (managed on server, not in Git) ─────────────
nginx/certs/

# ── Vercel build output ────────────────────────────────────
.vercel/

# ── Scratch scripts ────────────────────────────────────────
clear_db.py
inspect_db.py
